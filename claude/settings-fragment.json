{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_ENABLE_TELEMETRY": "0",
		"MAX_THINKING_TOKENS": "16000",
		"_ZO_DOCTOR": "0"
	},
	"effortLevel": "high",
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"permissions": {
		"allow": [
			"Bash(awk:*)",
			"Bash(basename:*)",
			"Bash(biome:*)",
			"Bash(cat:*)",
			"Bash(cd:*)",
			"Bash(corepack:*)",
			"Bash(cp:*)",
			"Bash(cut:*)",
			"Bash(date:*)",
			"Bash(diff:*)",
			"Bash(dirname:*)",
			"Bash(du:*)",
			"Bash(echo:*)",
			"Bash(false)",
			"Bash(find:*)",
			"Bash(gh issue create:*)",
			"Bash(gh issue list:*)",
			"Bash(gh issue view:*)",
			"Bash(gh pr checks:*)",
			"Bash(gh pr create:*)",
			"Bash(gh pr diff:*)",
			"Bash(gh pr list:*)",
			"Bash(gh pr view:*)",
			"Bash(gh repo view:*)",
			"Bash(gh run list:*)",
			"Bash(gh run view:*)",
			"Bash(git add:*)",
			"Bash(git branch:*)",
			"Bash(git checkout:*)",
			"Bash(git commit:*)",
			"Bash(git diff-tree:*)",
			"Bash(git diff:*)",
			"Bash(git fetch:*)",
			"Bash(git log:*)",
			"Bash(git merge:*)",
			"Bash(git remote:*)",
			"Bash(git rev-parse:*)",
			"Bash(git show:*)",
			"Bash(git stash:*)",
			"Bash(git status:*)",
			"Bash(git tag:*)",
			"Bash(git worktree:*)",
			"Bash(glab ci *)",
			"Bash(glab issue *)",
			"Bash(glab mr *)",
			"Bash(grep:*)",
			"Bash(head:*)",
			"Bash(jest:*)",
			"Bash(jq:*)",
			"Bash(ls:*)",
			"Bash(md5 *)",
			"Bash(mkdir:*)",
			"Bash(mv:*)",
			"Bash(node:*)",
			"Bash(openspec:*)",
			"Bash(playwright:*)",
			"Bash(pnpm:*)",
			"Bash(pnpx:*)",
			"Bash(printf:*)",
			"Bash(pwd)",
			"Bash(rg:*)",
			"Bash(sed:*)",
			"Bash(sort:*)",
			"Bash(stat:*)",
			"Bash(tail:*)",
			"Bash(tee:*)",
			"Bash(test:*)",
			"Bash(touch:*)",
			"Bash(tr:*)",
			"Bash(true)",
			"Bash(tsc:*)",
			"Bash(turbo:*)",
			"Bash(uniq:*)",
			"Bash(uv:*)",
			"Bash(uvx:*)",
			"Bash(vitest:*)",
			"Bash(wc:*)",
			"Bash(which:*)",
			"Bash(xargs:*)",
			"Edit",
			"Glob",
			"Grep",
			"mcp__plugin_context7_context7__query-docs",
			"mcp__plugin_context7_context7__resolve-library-id",
			"mcp__plugin_playwright_playwright__browser_click",
			"mcp__plugin_playwright_playwright__browser_close",
			"mcp__plugin_playwright_playwright__browser_evaluate",
			"mcp__plugin_playwright_playwright__browser_fill_form",
			"mcp__plugin_playwright_playwright__browser_navigate",
			"mcp__plugin_playwright_playwright__browser_run_code",
			"mcp__plugin_playwright_playwright__browser_snapshot",
			"mcp__plugin_playwright_playwright__browser_take_screenshot",
			"Read",
			"Skill(commit-commands:*)",
			"WebFetch(domain:api.github.com)",
			"WebFetch(domain:builder.aws.com)",
			"WebFetch(domain:cdn.playwright.dev)",
			"WebFetch(domain:community.aws)",
			"WebFetch(domain:docs.amplify.aws)",
			"WebFetch(domain:fonts.googleapis.com)",
			"WebFetch(domain:github.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:registry.npmjs.org)",
			"WebFetch(domain:repost.aws)",
			"WebSearch",
			"Write"
		],
		"deny": [
			"Bash(rm -rf /:*)",
			"Bash(rm -rf /*)",
			"Bash(rm -rf ~:*)",
			"Bash(rm -rf ~/:*)",
			"Bash(rm -rf $HOME:*)",
			"Bash(rm -rf /System:*)",
			"Bash(rm -rf /Library:*)",
			"Bash(rm -rf /Users:*)",
			"Bash(sudo:*)",
			"Bash(git push --force:*)",
			"Read(//**/.env)",
			"Read(//**/.env.*)",
			"Edit(//**/.env)",
			"Edit(//**/.env.*)",
			"Read(~/.ssh/authorized_keys)",
			"Read(~/.ssh/id_*)",
			"Read(~/.aws/credentials)",
			"Read(~/.aws/sso/**)",
			"Read(~/Library/Keychains/**)"
		],
		"ask": [
			"Bash(git push:*)",
			"Bash(git push --force-with-lease:*)",
			"Bash(git checkout -- *)",
			"Bash(git reset --hard*)",
			"Bash(git clean*)",
			"Bash(gh pr merge:*)",
			"Bash(gh repo delete:*)",
			"Bash(glab api *)",
			"Bash(docker:*)",
			"Bash(curl:*)",
			"Bash(pnpm publish:*)"
		],
		"defaultMode": "default",
		"additionalDirectories": [
			"/tmp",
			"/private/tmp",
			"~/Library/pnpm/store",
			"~/.npm",
			"~/.claude/plugins",
			"~/Library/Caches/typescript",
			"~/Library/Caches/dev.biomejs.biome",
			"~/Library/Caches/ms-playwright"
		]
	},
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "/opt/homebrew/bin/terminal-notifier -title 'Claude Code' -message 'Claude Code needs your attention' -sound Glass"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/agent-teams-nudge.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/biome.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/stop-typecheck.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cat .claude/CONTEXT.md 2>/dev/null || true"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "/Users/benmoses/.claude/statusline-command.sh",
		"padding": 2
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true,
		"allowUnsandboxedCommands": true,
		"excludedCommands": ["git push", "git branch", "git remote", "git config"],
		"network": {
			"allowedDomains": [
				"registry.npmjs.org",
				"registry.yarnpkg.com",
				"github.com",
				"api.github.com",
				"codeload.github.com",
				"objects.githubusercontent.com",
				"raw.githubusercontent.com",
				"pypi.org",
				"files.pythonhosted.org",
				"cli.cdk.dev-tools.aws.dev",
				"biomejs.dev",
				"pnpm.io",
				"amazonaws.com",
				"*.amazonaws.com"
			],
			"allowLocalBinding": true,
			"allowAllUnixSockets": true,
			"allowMachLookup": [
				"com.apple.trustd",
				"com.apple.trustd.agent",
				"com.apple.securityd",
				"com.apple.SecurityServer",
				"com.apple.SecurityServer.xpc",
				"com.apple.CoreAuthentication.daemon",
				"com.apple.cfprefsd.daemon",
				"com.apple.cfprefsd.agent"
			]
		},
		"filesystem": {
			"allowWrite": [
				"/var/folders/*/*/T/**",
				"/tmp/**",
				"/private/tmp/**",
				"~/.ssh/known_hosts",
				"~/Library/pnpm/**",
				"~/.local/state/pnpm/**",
				"~/Library/Caches/pnpm/**",
				"~/.npm/**",
				"~/.cache/node/**",
				"~/Library/Caches/typescript/**",
				"~/Library/Caches/dev.biomejs.biome/**",
				"~/Library/Caches/ms-playwright/**",
				"~/Library/Caches/node-gyp/**"
			],
			"allowRead": [
				"~/.ssh/id_rsa",
				"~/.ssh/id_rsa.pub",
				"~/.ssh/id_ecdsa",
				"~/.ssh/known_hosts",
				"~/.ssh/config",
				"~/.config/gh/**",
				"~/Library/Keychains/**"
			]
		}
	},
	"tui": "fullscreen",
	"awaySummaryEnabled": true,
	"skipWorkflowUsageWarning": true,
	"autoUpdatesChannel": "stable",
	"theme": "dark-ansi",
	"teammateMode": "tmux",
	"autoDreamEnabled": true
}
