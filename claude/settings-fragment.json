{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_ENABLE_TELEMETRY": "0",
		"_ZO_DOCTOR": "0"
	},
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"permissions": {
		"allow": [
			"Bash(biome *)",
			"Bash(cat:*)",
			"Bash(cd:*)",
			"Bash(curl:-s \"https://registry.npmjs.org/*)",
			"Bash(date:*)",
			"Bash(echo:*)",
			"Bash(gh issue create *)",
			"Bash(gh issue list *)",
			"Bash(gh repo view *)",
			"Bash(git -C */** diff:*)",
			"Bash(git add:*)",
			"Bash(git branch:*)",
			"Bash(git checkout:*)",
			"Bash(git commit:*)",
			"Bash(git diff-tree:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git merge:*)",
			"Bash(git stash:*)",
			"Bash(git status:*)",
			"Bash(git tag:*)",
			"Bash(git worktree:*)",
			"Bash(grep:*)",
			"Bash(head:*)",
			"Bash(ls:*)",
			"Bash(mkdir:*)",
			"Bash(node:*)",
			"Bash(nvm use:*)",
			"Bash(pnpm add *)",
			"Bash(pnpm build:*)",
			"Bash(pnpm format)",
			"Bash(pnpm init)",
			"Bash(pnpm install:*)",
			"Bash(pnpm lint:*)",
			"Bash(pnpm run:*)",
			"Bash(pnpm test:*)",
			"Bash(pnpm typecheck)",
			"Bash(sort:*)",
			"Bash(tail:*)",
			"Bash(tr:*)",
			"Bash(tsc *)",
			"Bash(wc:*)",
			"Edit",
			"Glob",
			"Grep",
			"mcp__plugin_context7_context7__query-docs",
			"mcp__plugin_context7_context7__resolve-library-id",
			"mcp__plugin_playwright_playwright__browser_click",
			"mcp__plugin_playwright_playwright__browser_close",
			"mcp__plugin_playwright_playwright__browser_evaluate",
			"mcp__plugin_playwright_playwright__browser_fill_form",
			"mcp__plugin_playwright_playwright__browser_navigate",
			"mcp__plugin_playwright_playwright__browser_run_code",
			"mcp__plugin_playwright_playwright__browser_snapshot",
			"mcp__plugin_playwright_playwright__browser_take_screenshot",
			"Read",
			"Skill(commit-commands:*)",
			"WebFetch(domain:api.github.com)",
			"WebFetch(domain:builder.aws.com)",
			"WebFetch(domain:cdn.playwright.dev)",
			"WebFetch(domain:community.aws)",
			"WebFetch(domain:docs.amplify.aws)",
			"WebFetch(domain:fonts.googleapis.com)",
			"WebFetch(domain:github.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:registry.npmjs.org)",
			"WebFetch(domain:repost.aws)",
			"WebSearch",
			"Write"
		],
		"deny": [
			"Bash(rm -rf:*)",
			"Bash(sudo:*)",
			"Bash(git push --force:*)",
			"Read(.env)",
			"Read(.env.*)",
			"Read(~/.ssh/**)",
			"Read(~/.aws/**)",
			"Read(~/Library/Keychains/**)"
		],
		"ask": ["Bash(git push:*)", "Bash(docker:*)", "Bash(curl:*)"],
		"additionalDirectories": [
			"~/Library/pnpm/store",
			"/Users/benmoses/.claude/plugins/cache/claude-plugins-official/superpowers",
			"/Users/benmoses/Library/pnpm/store",
			"/Users/benmoses/.config/superpowers/worktrees"
		]
	},
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/DesktopNotification.app/Contents/MacOS/applet"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/biome.sh"
					},
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/ts-typecheck.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cat .claude/CONTEXT.md 2>/dev/null || true"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "/Users/benmoses/.claude/statusline-command.sh",
		"padding": 2
	},
	"sandbox": {
		"enabled": true,
		"allowUnsandboxedCommands": false,
		"network": {
			"allowLocalBinding": true
		}
	},
	"tui": "fullscreen",
	"theme": "dark-ansi",
	"teammateMode": "tmux",
	"autoDreamEnabled": true
}
