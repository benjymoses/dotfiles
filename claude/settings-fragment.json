{
    "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(nvm use:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(git commit:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/Library/Keychains/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(docker:*)",
      "Bash(curl:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/benmoses/.claude/DesktopNotification.app/Contents/MacOS/applet"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/benmoses/.claude/statusline-command.sh",
    "padding": 2
  },
  "teammateMode": "tmux",
  "autoDreamEnabled": true
}