{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_CODE_ENABLE_TELEMETRY": "0",
		"MAX_THINKING_TOKENS": "4096",
		"_ZO_DOCTOR": "0"
	},
	"effortLevel": "medium",
	"attribution": {
		"commit": "",
		"pr": ""
	},
	"permissions": {
		"allow": [
			"Bash(awk:*)",
			"Bash(basename:*)",
			"Bash(biome:*)",
			"Bash(cat:*)",
			"Bash(cd:*)",
			"Bash(corepack:*)",
			"Bash(cp:*)",
			"Bash(cut:*)",
			"Bash(date:*)",
			"Bash(diff:*)",
			"Bash(dirname:*)",
			"Bash(echo:*)",
			"Bash(false)",
			"Bash(find:*)",
			"Bash(gh issue create:*)",
			"Bash(gh issue list:*)",
			"Bash(gh pr create:*)",
			"Bash(gh pr list:*)",
			"Bash(gh pr view:*)",
			"Bash(gh repo view:*)",
			"Bash(git add:*)",
			"Bash(git branch:*)",
			"Bash(git checkout:*)",
			"Bash(git commit:*)",
			"Bash(git diff-tree:*)",
			"Bash(git diff:*)",
			"Bash(git log:*)",
			"Bash(git merge:*)",
			"Bash(git stash:*)",
			"Bash(git status:*)",
			"Bash(git tag:*)",
			"Bash(git worktree:*)",
			"Bash(glab api *)",
			"Bash(glab ci *)",
			"Bash(glab issue *)",
			"Bash(glab mr *)",
			"Bash(grep:*)",
			"Bash(head:*)",
			"Bash(jest:*)",
			"Bash(jq:*)",
			"Bash(ls:*)",
			"Bash(md5 *)",
			"Bash(mkdir:*)",
			"Bash(mv:*)",
			"Bash(node:*)",
			"Bash(nvm use:*)",
			"Bash(playwright:*)",
			"Bash(pnpm:*)",
			"Bash(pnpx:*)",
			"Bash(printf:*)",
			"Bash(pwd)",
			"Bash(rm:*)",
			"Bash(rg:*)",
			"Bash(sed:*)",
			"Bash(sort:*)",
			"Bash(tail:*)",
			"Bash(test:*)",
			"Bash(tr:*)",
			"Bash(true)",
			"Bash(tsc:*)",
			"Bash(turbo:*)",
			"Bash(uv:*)",
			"Bash(uvx:*)",
			"Bash(vitest:*)",
			"Bash(wc:*)",
			"Bash(which:*)",
			"Bash(xargs:*)",
			"Bash(yes:*)",
			"Edit",
			"Glob",
			"Grep",
			"mcp__plugin_context7_context7__query-docs",
			"mcp__plugin_context7_context7__resolve-library-id",
			"mcp__plugin_playwright_playwright__browser_click",
			"mcp__plugin_playwright_playwright__browser_close",
			"mcp__plugin_playwright_playwright__browser_evaluate",
			"mcp__plugin_playwright_playwright__browser_fill_form",
			"mcp__plugin_playwright_playwright__browser_navigate",
			"mcp__plugin_playwright_playwright__browser_run_code",
			"mcp__plugin_playwright_playwright__browser_snapshot",
			"mcp__plugin_playwright_playwright__browser_take_screenshot",
			"Read",
			"Skill(commit-commands:*)",
			"WebFetch(domain:api.github.com)",
			"WebFetch(domain:builder.aws.com)",
			"WebFetch(domain:cdn.playwright.dev)",
			"WebFetch(domain:community.aws)",
			"WebFetch(domain:docs.amplify.aws)",
			"WebFetch(domain:fonts.googleapis.com)",
			"WebFetch(domain:github.com)",
			"WebFetch(domain:raw.githubusercontent.com)",
			"WebFetch(domain:registry.npmjs.org)",
			"WebFetch(domain:repost.aws)",
			"WebSearch",
			"Write"
		],
		"deny": [
			"Bash(rm -rf /:*)",
			"Bash(rm -rf /*)",
			"Bash(rm -rf ~:*)",
			"Bash(rm -rf ~/:*)",
			"Bash(rm -rf $HOME:*)",
			"Bash(rm -rf /System:*)",
			"Bash(rm -rf /Library:*)",
			"Bash(rm -rf /Users:*)",
			"Bash(sudo:*)",
			"Bash(git push --force:*)",
			"Read(.env)",
			"Read(.env.*)",
			"Read(~/.ssh/authorized_keys)",
			"Read(~/.aws/credentials)",
			"Read(~/.aws/sso/**)",
			"Read(~/Library/Keychains/**)"
		],
		"ask": [
			"Bash(git push:*)",
			"Bash(git push --force-with-lease:*)",
			"Bash(docker:*)",
			"Bash(curl:*)",
			"Bash(pnpm publish:*)"
		],
		"additionalDirectories": [
			"~/Library/pnpm/store",
			"/Users/benmoses/.claude/plugins/cache/claude-plugins-official/superpowers",
			"/Users/benmoses/Library/pnpm/store",
			"/Users/benmoses/.local/state/pnpm",
			"/Users/benmoses/Library/Caches/pnpm",
			"/Users/benmoses/.npm",
			"/Users/benmoses/.cache/node",
			"/Users/benmoses/Library/Caches/typescript",
			"/Users/benmoses/Library/Caches/dev.biomejs.biome",
			"/Users/benmoses/Library/Caches/ms-playwright",
			"/Users/benmoses/Library/Caches/node-gyp",
			"/tmp",
			"/private/tmp"
		]
	},
	"hooks": {
		"Notification": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/DesktopNotification.app/Contents/MacOS/applet"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Agent",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/agent-teams-nudge.sh"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "rtk hook claude"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/biome.sh"
					},
					{
						"type": "command",
						"command": "/Users/benmoses/.claude/hooks/ts-typecheck.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cat .claude/CONTEXT.md 2>/dev/null || true"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "/Users/benmoses/.claude/statusline-command.sh",
		"padding": 2
	},
	"sandbox": {
		"enabled": true,
		"allowUnsandboxedCommands": false,
		"network": {
			"allowLocalBinding": true,
			"allowMachLookup": ["com.apple.trustd", "com.apple.trustd.agent"],
			"allowAllUnixSockets": true
		},
		"filesystem": {
			"allowRead": [
				"~/.ssh/id_rsa",
				"~/.ssh/id_rsa.pub",
				"~/.ssh/id_ecdsa",
				"~/.ssh/known_hosts",
				"~/.ssh/config"
			],
			"allowWrite": ["/var/folders/*/*/T/**", "~/.ssh/known_hosts"]
		}
	},
	"tui": "fullscreen",
	"autoUpdatesChannel": "stable",
	"theme": "dark-ansi",
	"teammateMode": "tmux",
	"autoDreamEnabled": true
}
